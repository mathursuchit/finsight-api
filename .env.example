# Copy to .env and fill in values

# Model settings
MODEL_NAME=microsoft/phi-3-mini-4k-instruct
ADAPTER_PATH=                         # path to fine-tuned LoRA adapter (leave empty for base model)
LOAD_IN_4BIT=true                     # set false if no GPU
MAX_NEW_TOKENS=512
TEMPERATURE=0.3
TOP_P=0.9

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=finsight-finetuning

# API
CORS_ORIGINS=["*"]
